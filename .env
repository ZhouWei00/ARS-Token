# Environment Variables for ARSITEK Token Deployment

# Wallet Private Key (NEVER SHARE THIS)
PRIVATE_KEY=your_private_key_here

# BSCScan API Key for verification
BSCSCAN_API_KEY=your_bscscan_api_key_here

# BSC Network URLs
BSC_TESTNET_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_MAINNET_URL=https://bsc-dataseed.binance.org/

# Wallet Addresses
MARKETING_WALLET=0xYourMarketingWalletAddress
TREASURY_WALLET=0xYourTreasuryWalletAddress